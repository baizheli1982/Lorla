<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  lorla 私人播放器 - 4K点对点超清启动闪屏配置文件
  优化点：增加了骨架标签、移除了不稳定的基础图片依赖、增加了首次启动的自动跳转逻辑
-->
<window>
    <defaultcontrol></defaultcontrol>
    <!-- 声明该页面的整体虚拟分辨率为 4K 标准 -->
    <width>3840</width>
    <height>2160</height>
    
    <!-- 满足 Kodi 引擎硬性硬性检测的骨架标签 -->
    <views></views> 

    <!-- 核心逻辑：当本窗口加载完成后，等待系统后台初始化完毕，自动跳转到主界面(10000) -->
    <onload>ReplaceWindow(home)</onload>

    <controls>
        <!-- 1. 全屏纯黑色遮罩层（使用原生无损纯黑定义，杜绝图片丢失引起的穿帮） -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>3840</width>
            <height>2160</height>
            <!-- #FF000000 代表完全不透明的纯黑色 -->
            <texture>#FF000000</texture> 
        </control>

        <!-- 2. 正中央点对点放置你的 lorla 闪屏图 -->
        <control type="image">
            <left>1232</left>   <!-- 居中计算公式：(3840 - 1376) / 2 -->
            <top>696</top>     <!-- 居中计算公式：(2160 - 768) / 2 -->
            <width>1376</width>  <!-- 严格锁定图片的原始物理宽度 -->
            <height>768</height>  <!-- 严格锁定图片的原始物理高度 -->
            <texture>lorla_splash.png</texture> <!-- 请确保该图片放在皮肤的 media 目录下 -->
            <aspectratio>keep</aspectratio> <!-- 强制保持比例，打死也不拉伸变形 -->
        </control>
    </controls>
</window>
